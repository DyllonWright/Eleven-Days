{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"allowJs": false,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true,
		"importHelpers": false,
		"lib": ["DOM", "ES2018", "ES2020.String"]
	},
	"include": ["src/**/*.ts"]
}
